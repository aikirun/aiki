{
	"name": "aiki",
	"private": true,
	"type": "module",
	"workspaces": [
		"app/server",
		"app/dashboard",
		"cli",
		"examples",
		"lib",
		"sdk/client",
		"sdk/endpoint",
		"sdk/adapter/http",
		"sdk/adapter/memory",
		"sdk/adapter/redis",
		"sdk/iam",
		"sdk/server",
		"sdk/worker",
		"sdk/workflow",
		"testing",
		"types"
	],
	"scripts": {
		"check": "tsc --noEmit && tsc --noEmit -p app/dashboard/tsconfig.json",
		"lint": "bunx @biomejs/biome check .",
		"lint:fix": "bunx @biomejs/biome check --write .",
		"test:watch": "bun test --watch",
		"test:coverage": "bun test --coverage",
		"db:generate:server": "bun run --cwd sdk/server db:generate",
		"db:generate:server:custom": "bun run --cwd sdk/server db:generate:custom",
		"db:generate:iam": "bun run --cwd sdk/iam db:generate",
		"db:generate:iam:custom": "bun run --cwd sdk/iam db:generate:custom",
		"db:generate": "bun run db:generate:server && bun run db:generate:iam",
		"db:migrate:server": "bun run --cwd app/server db:migrate:server",
		"db:migrate:iam": "bun run --cwd app/server db:migrate:iam",
		"db:migrate": "bun run --cwd app/server db:migrate",
		"server": "bun run --cwd app/server start",
		"server:watch": "bun run --cwd app/server start:watch",
		"dashboard": "bun run --cwd app/dashboard dev",
		"bump": "bun scripts/bump.ts",
		"tag": "bun scripts/tag.ts",
		"clean": "rm -rf lib/dist types/dist app/server/dist app/dashboard/dist cli/dist sdk/*/dist sdk/adapter/*/dist sdk/iam/dist",
		"build:lib": "bun run --cwd lib build",
		"build:types": "bun run --cwd types build",
		"build:sdk": "bun run --cwd sdk/workflow build && bun run --cwd sdk/client build && bun run --cwd sdk/worker build && bun run --cwd sdk/endpoint build && bun run --cwd sdk/server build && bun run --cwd sdk/iam build && bun run --cwd sdk/adapter/http build && bun run --cwd sdk/adapter/memory build && bun run --cwd sdk/adapter/redis build",
		"build:cli": "bun run --cwd cli build",
		"build:server": "bun run --cwd app/server build",
		"build:dashboard": "bun run --cwd app/dashboard build",
		"build:packages": "bun run build:lib && bun run build:types && bun run build:sdk && bun run build:cli",
		"build:all": "bun run build:packages && bun run build:server && bun run build:dashboard",
		"docker:build": "docker compose build",
		"docker:up": "docker compose up -d",
		"docker:down": "docker compose down",
		"docker:logs": "docker compose logs -f",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,json}": [
			"bunx @biomejs/biome check --write"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.2",
		"@types/node": "^26.1.0",
		"bun-types": "^1.1.38",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"tsup": "^8.5.1",
		"typescript": "^6.0.3"
	},
	"overrides": {
		"better-auth": "1.6.11"
	}
}
