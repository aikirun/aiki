{
	"name": "aiki",
	"private": true,
	"type": "module",
	"workspaces": [
		"app/server",
		"app/dashboard",
		"app/website",
		"cli",
		"examples",
		"lib",
		"sdk/client",
		"sdk/endpoint",
		"sdk/adapter/http",
		"sdk/adapter/memory",
		"sdk/adapter/redis",
		"sdk/iam",
		"sdk/server",
		"sdk/worker",
		"sdk/workflow",
		"testing",
		"types"
	],
	"scripts": {
		"check": "tsc --noEmit && tsc --noEmit -p app/dashboard/tsconfig.json && bun run --cwd app/website check",
		"lint": "bunx @biomejs/biome check .",
		"lint:fix": "bunx @biomejs/biome check --write .",
		"test:watch": "bun test --watch",
		"test:coverage": "bun test --coverage",
		"db:migrate:generate": "bun run --cwd sdk/server db:migrate:generate && bun run --cwd sdk/iam db:migrate:generate",
		"db:migrate:apply": "bun run --cwd app/server db:migrate:apply",
		"db:migrate:apply:server": "bun run --cwd app/server db:migrate:apply:server",
		"db:migrate:apply:iam": "bun run --cwd app/server db:migrate:apply:iam",
		"server": "bun run --cwd app/server start",
		"server:watch": "bun run --cwd app/server start:watch",
		"dashboard": "bun run --cwd app/dashboard dev",
		"website": "bun run --cwd app/website dev",
		"bump": "bun scripts/bump.ts",
		"clean": "rm -rf lib/dist types/dist app/server/dist app/dashboard/dist cli/dist sdk/*/dist sdk/adapter/*/dist sdk/iam/dist app/website/build app/website/.react-router app/website/.source",
		"build:lib": "bun run --cwd lib build",
		"build:types": "bun run --cwd types build",
		"build:sdk": "bun run --filter='./sdk/*' --filter='./sdk/adapter/*' build",
		"build:packages": "bun run --filter='./lib' --filter='./types' --filter='./sdk/*' --filter='./sdk/adapter/*' build",
		"build:server": "bun run --cwd app/server build",
		"build:dashboard": "bun run --cwd app/dashboard build",
		"build:website": "bun run --cwd app/website build",
		"build:cli": "bun run --cwd cli build",
		"build:all": "bun run --filter='*' build",
		"docker:build": "docker compose build",
		"docker:up": "docker compose up -d",
		"docker:down": "docker compose down",
		"docker:logs": "docker compose logs -f",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,json}": [
			"bunx @biomejs/biome check --write"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.9",
		"@types/node": "^22.10.2",
		"bun-types": "^1.1.38",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"tsup": "^8.5.1",
		"typescript": "^5.7.2"
	},
	"overrides": {
		"better-auth": "1.6.11"
	}
}
