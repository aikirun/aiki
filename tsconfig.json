{
	"compilerOptions": {
		"strict": true,
		"useUnknownInCatchVariables": true,
		"noImplicitOverride": true,
		"noUncheckedIndexedAccess": true,

		"module": "ESNext",
		"moduleResolution": "bundler",
		"target": "ES2022",

		"baseUrl": ".",
		"paths": {
			"@aikirun/app-server": ["./app/server/src/index.ts"],
			"@aikirun/client": ["./sdk/client/src/index.ts"],
			"@aikirun/endpoint": ["./sdk/endpoint/src/index.ts"],
			"@aikirun/iam": ["./sdk/iam/src/index.ts"],
			"@aikirun/iam/*": ["./sdk/iam/src/*/index.ts", "./sdk/iam/src/*.ts"],
			"@aikirun/lib/*": ["./lib/src/*/index.ts", "./lib/src/*.ts"],
			"@aikirun/http": ["./sdk/adapter/http/src/index.ts"],
			"@aikirun/memory": ["./sdk/adapter/memory/src/index.ts"],
			"@aikirun/redis": ["./sdk/adapter/redis/src/index.ts"],
			"@aikirun/server": ["./sdk/server/src/index.ts"],
			"@aikirun/server/*": ["./sdk/server/src/*/index.ts", "./sdk/server/src/*.ts"],
			"@aikirun/testing/*": ["./testing/src/*/index.ts", "./testing/src/*.ts"],
			"@aikirun/types/*": ["./types/src/*/index.ts", "./types/src/*.ts"],
			"@aikirun/worker": ["./sdk/worker/src/index.ts"],
			"@aikirun/workflow": ["./sdk/workflow/src/index.ts"]
		},

		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,

		"noEmit": true,

		"types": ["bun-types", "@types/node"]
	},
	"include": [
		"lib/**/*",
		"types/**/*",
		"sdk/**/*",
		"testing/**/*",
		"app/server/**/*",
		"cli/**/*",
		"examples/**/*",
		"scripts/**/*"
	],
	"exclude": ["node_modules", "**/dist"]
}
