AIKI_SERVER_HOST=0.0.0.0
AIKI_SERVER_PORT=9850

# Optional: Set if auth is needed
# AIKI_SERVER_BASE_URL=http://localhost:9850
# AIKI_SERVER_AUTH_SECRET=yourSecretKey

CORS_ORIGINS=http://localhost:9851

# Optional: Redis for lower-latency message delivery
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

DATABASE_PROVIDER=pg

DATABASE_URL=postgresql://user:password@localhost:5432/aiki
DATABASE_MAX_CONNECTIONS=10
# To verify the DB's cert against a private CA (e.g. DigitalOcean, RDS), set its PEM contents here:
# DATABASE_CA_CERT=

LOG_LEVEL=info
PRETTY_LOGS=true
