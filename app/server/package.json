{
	"name": "@aikirun/app-server",
	"version": "0.27.0",
	"private": true,
	"type": "module",
	"main": "./index.ts",
	"scripts": {
		"start": "bun run index.ts",
		"start:watch": "bun --watch run index.ts",
		"build": "bun build index.ts --compile --outfile dist/aiki-server",
		"db:migrate": "aiki migrate apply --env-file ./.env",
		"db:generate": "aiki migrate generate --env-file ./.env",
		"db:generate:custom": "aiki migrate generate --custom --env-file ./.env"
	},
	"dependencies": {
		"@aikirun/lib": "workspace:*",
		"@aikirun/redis": "workspace:*",
		"@aikirun/server": "workspace:*",
		"@aikirun/types": "workspace:*",
		"arktype": "^2.1.29",
		"dotenv": "^16.4.5",
		"ioredis": "^5.4.1",
		"pino": "^9.6.0",
		"pino-pretty": "^13.0.0"
	},
	"devDependencies": {
		"@aikirun/cli": "workspace:*"
	},
	"license": "Apache-2.0"
}
