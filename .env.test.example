# Copy to .env.test and point it at a DEDICATED test database.
#
# The integration suite (bun run test:integration) truncates every table before each
# test, so this must be a database used ONLY for tests — never a real one.
#
# Pre-migrate it once before running the suite:
#   bun run db:migrate:test:apply

DATABASE_PROVIDER=pg
DATABASE_URL=postgresql://user:password@localhost:5432/aiki_test
DATABASE_MAX_CONNECTIONS=1
