{
	"name": "@aikirun/server",
	"version": "0.35.0",
	"description": "Aiki server library — durable execution orchestrator.",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"bin": {
		"aiki-server": "./dist/bin.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"db:migrate:generate": "bun scripts/db-migrate-generate.ts",
		"db:migrate:generate:custom": "bun scripts/db-migrate-generate.ts --custom"
	},
	"dependencies": {
		"@aikirun/types": "workspace:*",
		"@orpc/contract": "^1.9.3",
		"@orpc/server": "^1.9.3",
		"arktype": "^2.1.29",
		"cac": "^6.7.14",
		"cron-parser": "^5.4.0",
		"dotenv": "^16.4.5",
		"drizzle-orm": "^0.45.1",
		"ulidx": "^2.4.1"
	},
	"peerDependencies": {
		"postgres": "^3.4.8"
	},
	"peerDependenciesMeta": {
		"postgres": {
			"optional": true
		}
	},
	"devDependencies": {
		"@aikirun/lib": "workspace:*",
		"@aikirun/memory": "workspace:*",
		"drizzle-kit": "^0.31.8",
		"postgres": "^3.4.8"
	},
	"publishConfig": {
		"access": "public"
	},
	"license": "Apache-2.0"
}
