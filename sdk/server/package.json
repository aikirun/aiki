{
	"name": "@aikirun/server",
	"version": "0.29.1",
	"description": "Aiki server library — durable execution orchestrator.",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"db:generate": "aiki migrate generate --package server",
		"db:generate:custom": "aiki migrate generate --package server --custom"
	},
	"dependencies": {
		"@aikirun/types": "workspace:*",
		"@orpc/contract": "^1.9.3",
		"@orpc/server": "^1.9.3",
