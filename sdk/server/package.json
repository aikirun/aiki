		"postgres": "^3.4.8"
	},
	"peerDependenciesMeta": {
		"postgres": {
			"optional": true
		}
	},
	"devDependencies": {
		"@aikirun/cli": "workspace:*",
		"@aikirun/lib": "workspace:*",
